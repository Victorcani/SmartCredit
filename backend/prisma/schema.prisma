generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          Int          @id @default(autoincrement())
  name        String
  email       String       @unique
  income      Float
  simulations Simulation[]
}

model Simulation {
  id       Int   @id @default(autoincrement())
  userId   Int
  amount   Float
  term     Int
  user     User  @relation(fields: [userId], references: [id])
}